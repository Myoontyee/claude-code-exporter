{
  "name": "claude-code-exporter",
  "displayName": "Claude Code Exporter",
  "description": "Auto-export Claude Code CLI conversations to Markdown files. Watches ~/.claude/projects/ and keeps your chat history as readable .md files.",
  "version": "0.3.0",
  "publisher": "myoontyee",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "chat",
    "export",
    "markdown",
    "history"
  ],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Myoontyee/claude-code-exporter"
  },
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-code-exporter",
          "title": "Claude Code Exporter",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "claude-code-exporter": [
        {
          "id": "claudeCodeExporterSessions",
          "name": "Sessions",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeCodeExporter.refresh",
        "title": "Refresh Sessions",
        "icon": "$(refresh)",
        "category": "Claude Code Exporter"
      },
      {
        "command": "claudeCodeExporter.exportMenu",
        "title": "Export…",
        "icon": "$(cloud-download)",
        "category": "Claude Code Exporter"
      },
      {
        "command": "claudeCodeExporter.setOutputDirectory",
        "title": "Set Output Folder…",
        "icon": "$(folder)",
        "category": "Claude Code Exporter"
      },
      {
        "command": "claudeCodeExporter.openExportFolder",
        "title": "Open Export Folder",
        "icon": "$(folder-opened)",
        "category": "Claude Code Exporter"
      },
      {
        "command": "claudeCodeExporter.exportSession",
        "title": "Export This Session",
        "icon": "$(export)",
        "category": "Claude Code Exporter"
      },
      {
        "command": "claudeCodeExporter.openSession",
        "title": "Open Session Markdown",
        "icon": "$(go-to-file)",
        "category": "Claude Code Exporter"
      },
      {
        "command": "claudeCodeExporter.scanComputer",
        "title": "Scan Computer for Claude Conversations",
        "icon": "$(search)",
        "category": "Claude Code Exporter"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeCodeExporter.refresh",
          "when": "view == claudeCodeExporterSessions",
          "group": "navigation@1"
        },
        {
          "command": "claudeCodeExporter.exportMenu",
          "when": "view == claudeCodeExporterSessions",
          "group": "navigation@2"
        },
        {
          "command": "claudeCodeExporter.setOutputDirectory",
          "when": "view == claudeCodeExporterSessions",
          "group": "navigation@3"
        },
        {
          "command": "claudeCodeExporter.openExportFolder",
          "when": "view == claudeCodeExporterSessions",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeCodeExporter.exportSession",
          "when": "viewItem == session",
          "group": "inline@1"
        },
        {
          "command": "claudeCodeExporter.openSession",
          "when": "viewItem == session",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "Claude Code Exporter",
      "properties": {
        "claudeCodeExporter.autoExport": {
          "type": "boolean",
          "default": true,
          "description": "Automatically export conversations to .cc-history/ when updated."
        },
        "claudeCodeExporter.exportFormat": {
          "type": "string",
          "default": "readable",
          "enum": [
            "readable",
            "compact"
          ],
          "enumDescriptions": [
            "Rich Markdown with metadata table, collapsible tool calls — for archiving and human reading.",
            "Clean Human/Claude format, tool calls as one-line summaries — for pasting back into Claude as context."
          ],
          "description": "Export format."
        },
        "claudeCodeExporter.includeThinking": {
          "type": "boolean",
          "default": false,
          "description": "Include Claude's extended thinking blocks in exports."
        },
        "claudeCodeExporter.includeToolDetails": {
          "type": "boolean",
          "default": true,
          "description": "Include tool call details (collapsed in readable, one-line in compact)."
        },
        "claudeCodeExporter.claudeProjectsDir": {
          "type": "string",
          "default": "",
          "description": "Path to Claude Code projects directory. Defaults to ~/.claude/projects."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.20.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0"
  }
}
